# ── Required ────────────────────────────────────────────────────────────────
# API provider: "openrouter" (the only registered provider)
API_PROVIDER=openrouter

# OpenRouter API key — required when API_PROVIDER=openrouter
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Optional ────────────────────────────────────────────────────────────────
# Full-council deliberation timeout in seconds (default: 3600 = 60 min).
# Reasoning models are slow; deep mode can take a while.
# COUNCIL_TIMEOUT_SECONDS=3600

# Data directory root for the SQLite store (default: repo root → ./data).
# LLM_COUNCIL_ROOT=/abs/path/to/root
